{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Survey Response",
  "description": "A single respondent's complete response to the 13-question category structure survey.",
  "type": "object",
  "required": ["persona_id", "assigned_block_id", "completion_status", "responses", "metadata"],
  "additionalProperties": false,
  "properties": {
    "persona_id": {
      "type": "string",
      "pattern": "^R[0-9]{3}$"
    },
    "assigned_block_id": {
      "type": "string",
      "pattern": "^B[0-9]{1,2}$"
    },
    "completion_status": {
      "type": "string",
      "enum": ["partial", "complete"]
    },
    "responses": {
      "type": "object",
      "description": "Responses keyed by question ID (Q1-Q13).",
      "required": ["Q1", "Q2", "Q3", "Q4", "Q5", "Q6", "Q7", "Q8", "Q9", "Q10", "Q11", "Q12", "Q13"],
      "additionalProperties": false,
      "properties": {
        "Q1": {
          "type": "object",
          "description": "Domain engagement frequency (multiple_choice).",
          "required": ["response_value", "response_label"],
          "properties": {
            "response_value": { "type": "integer" },
            "response_label": { "type": "string" }
          }
        },
        "Q2": {
          "type": "object",
          "description": "Unaided entity recall (free_list).",
          "required": ["entities_listed"],
          "properties": {
            "entities_listed": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Free-text entity names as recalled by respondent."
            }
          }
        },
        "Q3": {
          "type": "object",
          "description": "Unaided category recall (free_list).",
          "required": ["categories_listed"],
          "properties": {
            "categories_listed": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Free-text category names as recalled by respondent."
            }
          }
        },
        "Q4": {
          "type": "object",
          "description": "Aided entity recognition (checklist). Block-scoped.",
          "required": ["recognized_entity_ids"],
          "properties": {
            "recognized_entity_ids": {
              "type": "array",
              "items": { "type": "string", "pattern": "^E[0-9]{3}$" },
              "description": "Entity IDs the respondent recognizes from their block."
            }
          }
        },
        "Q5": {
          "type": "object",
          "description": "Aided category recognition (checklist).",
          "required": ["recognized_category_ids"],
          "properties": {
            "recognized_category_ids": {
              "type": "array",
              "items": { "type": "string", "pattern": "^C[0-9]{2}$" },
              "description": "Category IDs the respondent recognizes."
            }
          }
        },
        "Q6": {
          "type": "object",
          "description": "Category pair hierarchy judgments (pair_comparison).",
          "required": ["pair_judgments"],
          "properties": {
            "pair_judgments": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["pair_id", "judgment"],
                "properties": {
                  "pair_id": { "type": "string", "pattern": "^P[0-9]{2}$" },
                  "judgment": {
                    "type": "string",
                    "enum": ["A_contains_B", "B_contains_A", "peers", "no_opinion"],
                    "description": "A_contains_B = A is parent of B, B_contains_A = B is parent of A, peers = same level."
                  }
                }
              }
            }
          }
        },
        "Q7": {
          "type": "object",
          "description": "Entity-to-category placement matrix. Conditional on Q5 (only categories recognized in Q5). Block-scoped entities.",
          "required": ["placements"],
          "properties": {
            "placements": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["entity_id", "category_ids"],
                "properties": {
                  "entity_id": { "type": "string", "pattern": "^E[0-9]{3}$" },
                  "category_ids": {
                    "type": "array",
                    "items": { "type": "string", "pattern": "^C[0-9]{2}$" },
                    "minItems": 1,
                    "maxItems": 3,
                    "description": "1-3 categories the respondent places this entity in."
                  }
                }
              },
              "description": "Each recognized entity placed into 1-3 recognized categories."
            }
          }
        },
        "Q8": {
          "type": "object",
          "description": "Conditional primary category assignment. Triggered for entities placed in 2+ categories in Q7.",
          "required": ["primary_assignments"],
          "properties": {
            "primary_assignments": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["entity_id", "primary_category_id"],
                "properties": {
                  "entity_id": { "type": "string", "pattern": "^E[0-9]{3}$" },
                  "primary_category_id": {
                    "type": "string",
                    "pattern": "^C[0-9]{2}$",
                    "description": "The single best-fit category for this entity."
                  }
                }
              },
              "description": "Primary assignment for each multi-placed entity from Q7."
            }
          }
        },
        "Q9": {
          "type": "object",
          "description": "Expanded micro-monopoly grid. For EVERY entity recognized in Q4, select the one category it 'owns' (from categories recognized in Q5) and provide a 3-5 word descriptor phrase. Conditional on Q4 (entity scope) and Q5 (category scope).",
          "required": ["selections"],
          "properties": {
            "selections": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["entity_id", "selected_category_id", "descriptor"],
                "properties": {
                  "entity_id": { "type": "string", "pattern": "^E[0-9]{3}$" },
                  "selected_category_id": {
                    "type": "string",
                    "pattern": "^C[0-9]{2}$",
                    "description": "The single category this entity 'owns' or dominates. Must be from categories recognized in Q5."
                  },
                  "descriptor": {
                    "type": "string",
                    "minLength": 5,
                    "maxLength": 50,
                    "description": "A 3-5 word phrase capturing the entity's unique positioning within its owned category (e.g., 'High protein low carb', 'Sleep stories meditation')."
                  }
                }
              }
            }
          }
        },
        "Q10": {
          "type": "object",
          "description": "Perceived category depth (scale 1-5 per category).",
          "required": ["depth_ratings"],
          "properties": {
            "depth_ratings": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["category_id", "depth_score"],
                "properties": {
                  "category_id": { "type": "string", "pattern": "^C[0-9]{2}$" },
                  "depth_score": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 5,
                    "description": "1=very shallow/few members to 5=very deep/many members."
                  }
                }
              },
              "description": "Depth perception for each recognized category."
            }
          }
        },
        "Q11": {
          "type": "object",
          "description": "Category boundary clarity (scale 1-5 per category).",
          "required": ["clarity_ratings"],
          "properties": {
            "clarity_ratings": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["category_id", "clarity_score"],
                "properties": {
                  "category_id": { "type": "string", "pattern": "^C[0-9]{2}$" },
                  "clarity_score": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 5,
                    "description": "1=very fuzzy boundaries to 5=very clear boundaries."
                  }
                }
              }
            }
          }
        },
        "Q12": {
          "type": "object",
          "description": "Overall category structure satisfaction (scale).",
          "required": ["satisfaction_score"],
          "properties": {
            "satisfaction_score": {
              "type": "integer",
              "minimum": 1,
              "maximum": 7,
              "description": "1=existing categories don't reflect reality to 7=categories perfectly capture the landscape."
            },
            "explanation": {
              "type": "string",
              "description": "Optional explanation of satisfaction rating."
            }
          }
        },
        "Q13": {
          "type": "object",
          "description": "Open-ended: missing categories or misclassified entities.",
          "required": ["response_text"],
          "properties": {
            "response_text": {
              "type": "string",
              "description": "Free-text response about gaps, misclassifications, or suggestions."
            }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["total_questions", "questions_answered", "completion_timestamp"],
      "additionalProperties": false,
      "properties": {
        "total_questions": { "type": "integer", "const": 13 },
        "questions_answered": { "type": "integer", "minimum": 1, "maximum": 13 },
        "completion_timestamp": { "type": "string" }
      }
    }
  }
}
